package handler

import (
	"context"
	"encoding/json"
	"errors"
	"log/slog"
	"net/http"
	"time"

	"{{.ModulePath}}/internal/config"
{{- if .Postgres}}
	"github.com/jackc/pgx/v5/pgxpool"
{{- end}}
{{- if .Redis}}
	"github.com/redis/go-redis/v9"
{{- end}}
	"github.com/go-chi/chi/v5"
	"github.com/go-chi/chi/v5/middleware"
	"github.com/go-chi/cors"
)

type Server struct {
	cfg *config.Config
	ctx context.Context
{{- if .Postgres}}
	db  *pgxpool.Pool
{{- end}}
{{- if .Redis}}
	rdb *redis.Client
{{- end}}
}

type apiResponse struct {
	RequestID string         `json:"request_id,omitempty"`
	Status    int            `json:"status"`
	Success   bool           `json:"success"`
	Data      map[string]any `json:"data,omitempty"`
}

func NewServer(
	ctx context.Context,
{{- if .Postgres}}
	db *pgxpool.Pool,
{{- end}}
{{- if .Redis}}
	rdb *redis.Client,
{{- end}}
	cfg *config.Config,
) *Server {
	return &Server{
		cfg: cfg,
		ctx: ctx,
{{- if .Postgres}}
		db:  db,
{{- end}}
{{- if .Redis}}
		rdb: rdb,
{{- end}}
	}
}

// JSON writes a standardised JSON envelope. respType is the key under "data" (e.g. "user", "order").
func (s *Server) JSON(w http.ResponseWriter, r *http.Request, status int, respType string, payload any) {
	rid := middleware.GetReqID(r.Context())
	resp := apiResponse{
		RequestID: rid,
		Status:    status,
		Success:   status >= 200 && status < 300,
	}
	if payload != nil {
		resp.Data = map[string]any{respType: payload}
	}

	w.Header().Set("Content-Type", "application/json; charset=utf-8")
	w.WriteHeader(status)

	if err := json.NewEncoder(w).Encode(resp); err != nil {
		slog.ErrorContext(r.Context(), "json encode failed",
			slog.Int("status", status),
			slog.String("error", err.Error()),
			slog.String("request_id", rid),
		)
	}
}

func (s *Server) Run() error {
	r := chi.NewMux()

	r.Use(cors.Handler(cors.Options{
		AllowedOrigins:   []string{"https://*", "http://*"},
		AllowedMethods:   []string{"GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"},
		AllowedHeaders:   []string{"Accept", "Authorization", "Content-Type"},
		AllowCredentials: true,
		MaxAge:           300,
	}))
	r.Use(middleware.RequestID)
	r.Use(middleware.Logger)
	r.Use(middleware.Recoverer)

	r.Get("/health", func(w http.ResponseWriter, r *http.Request) {
		s.JSON(w, r, http.StatusOK, "health", map[string]string{"status": "ok"})
	})

	// After running `go generate ./internal/api/...`, mount the generated router:
	// api.HandlerFromMux(s, r)

	srv := &http.Server{
		Addr:         s.cfg.ServerURL(),
		Handler:      r,
		ReadTimeout:  s.cfg.ReadTimeout(),
		WriteTimeout: s.cfg.WriteTimeout(),
		IdleTimeout:  s.cfg.IdleTimeout(),
	}

	go func() {
		if err := srv.ListenAndServe(); err != nil && !errors.Is(err, http.ErrServerClosed) {
			slog.Error("server error", slog.String("error", err.Error()))
		}
	}()

	slog.Info("server started", slog.String("addr", s.cfg.ServerURL()))

	<-s.ctx.Done()

	slog.Info("shutting down server...")

	shutdownCtx, cancel := context.WithTimeout(context.Background(), 10*time.Second)
	defer cancel()

	return srv.Shutdown(shutdownCtx)
}
