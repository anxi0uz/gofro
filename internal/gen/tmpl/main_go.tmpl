package main

import (
	"context"
	"errors"
	"log/slog"
	"net/http"
	"os"
	"os/signal"
	"syscall"

	"{{.ModulePath}}/internal/config"
{{- if or .Postgres .Redis}}
	"{{.ModulePath}}/internal/database"
{{- end}}
	"{{.ModulePath}}/internal/handler"
	"github.com/golang-cz/devslog"
)

func main() {
	ctx, cancel := context.WithCancel(context.Background())
	defer cancel()

	setupLogger()

	cfg, err := config.New(ctx, "configs/config.toml")
	if err != nil {
		slog.ErrorContext(ctx, "failed to load config", slog.String("error", err.Error()))
		os.Exit(1)
	}

	slog.SetLogLoggerLevel(cfg.App.LogLevel)
{{- if .Postgres}}

	pool, err := database.NewPostgresPool(ctx, cfg.DatabaseURL())
	if err != nil {
		slog.ErrorContext(ctx, "failed to connect to postgres", slog.String("error", err.Error()))
		os.Exit(1)
	}
	defer pool.Close()

	if err := database.RunMigrations(ctx, cfg.DatabaseURL()); err != nil {
		slog.ErrorContext(ctx, "failed to run migrations", slog.String("error", err.Error()))
		os.Exit(1)
	}
{{- end}}
{{- if .Redis}}

	rdb, err := database.NewRedisClient(ctx, cfg.Redis.Addr, cfg.Redis.Password, cfg.Redis.DB)
	if err != nil {
		slog.ErrorContext(ctx, "failed to connect to redis", slog.String("error", err.Error()))
		os.Exit(1)
	}
	defer func() {
		if err := rdb.Close(); err != nil {
			slog.Warn("redis close error", slog.String("error", err.Error()))
		}
	}()
{{- end}}

	sigChan := make(chan os.Signal, 1)
	signal.Notify(sigChan, syscall.SIGINT, syscall.SIGTERM, syscall.SIGHUP)

	serverErr := make(chan error, 1)
	go func() {
		serverErr <- handler.NewServer(
			ctx,
{{- if .Postgres}}
			pool,
{{- end}}
{{- if .Redis}}
			rdb,
{{- end}}
			cfg,
		).Run()
	}()

	select {
	case sig := <-sigChan:
		slog.InfoContext(ctx, "shutdown signal received", slog.String("signal", sig.String()))
	case err := <-serverErr:
		slog.ErrorContext(ctx, "server error", slog.String("error", err.Error()))
		os.Exit(1)
	}

	cancel()

	if err := <-serverErr; err != nil && !errors.Is(err, http.ErrServerClosed) {
		slog.ErrorContext(ctx, "server shutdown error", slog.String("error", err.Error()))
	}

	slog.InfoContext(ctx, "server stopped")
}

func setupLogger() {
	opts := &devslog.Options{
		TimeFormat:      "15:04:05.000",
		NewLineAfterLog: true,
	}
	slog.SetDefault(slog.New(devslog.NewHandler(os.Stdout, opts)))
}
